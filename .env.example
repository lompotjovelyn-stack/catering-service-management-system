PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cateringdb
DB_SSL=false
DB_SYNC_ALTER=true

# Use this instead of DB_HOST/DB_USER/etc when your cloud MySQL provider gives one URL.
# DATABASE_URL=mysql://user:password@host:3306/cateringdb

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
MAX_BOOKINGS_PER_DAY=3

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@catering.local
ADMIN_PASSWORD=Admin12345!

STAFF_NAME=Catering Staff
STAFF_EMAIL=staff@catering.local
STAFF_PASSWORD=Staff12345!

CUSTOMER_NAME=Sample Customer
CUSTOMER_EMAIL=customer@catering.local
CUSTOMER_PASSWORD=Customer12345!
